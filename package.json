{
  "name": "blok-lambdacalculus",
  "version": "1.0.0",
  "description": "A web-based block IDE for Block Lambda Calculus.",
  "private": true,
  "scripts": {
    "clean": "rimraf docs",
    "build": "webpack --mode production",
    "serve": "webpack serve --mode development --open",
    "dev": "webpack serve --mode development --open",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"playwright.config.ts\"",
    "test": "tsc -p tsconfig.test.json && node .test-build/tests/roundtrip.js && node .test-build/tests/semantics.js && node .test-build/tests/layoutState.js && node .test-build/tests/blockColors.js",
    "test:roundtrip": "tsc -p tsconfig.test.json && node .test-build/tests/roundtrip.js",
    "test:semantics": "tsc -p tsconfig.test.json && node .test-build/tests/semantics.js",
    "test:layout": "tsc -p tsconfig.test.json && node .test-build/tests/layoutState.js",
    "test:block-colors": "tsc -p tsconfig.test.json && node .test-build/tests/blockColors.js",
    "test:ui": "playwright test tests/ui/workbench.spec.ts",
    "test:ui:visual": "playwright test tests/ui/workbench.visual.spec.ts",
    "test:ui:update": "playwright test tests/ui/workbench.visual.spec.ts --update-snapshots"
  },
  "keywords": [
    "blockly",
    "lambda-calculus",
    "visual-programming",
    "typescript",
    "webpack"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "blockly": "^12.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.10",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^10.7.0",
    "html-webpack-plugin": "^5.6.0",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.65.0",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
